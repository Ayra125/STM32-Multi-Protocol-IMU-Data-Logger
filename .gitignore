# Firmware build outputs
build/
*.elf
*.bin
*.hex
*.map
*.lst
*.o

# IDE / tool project files
.vscode/
*.ioc
*.uvprojx
*.ewp

# OS metadata
.DS_Store
Thumbs.db

# Altium auto-generated folders
History/
__Previews/
__Previews__/
Project\ Logs\ for\ */
Project\ Outputs\ for\ */
*_PCBBackup*/
PreviewCache/

# Altium auto-generated files
*.PrjPcbStructure
*.PrjPcbStructure_MDAT

# Altium compiled libraries (binary artefacts; track source .SchLib/.PcbLib instead)
*.IntLib
*.Lib

# Altium report / log files
*.REP
*.Rpt
*.rpt
*.DRR
*.RUL
*.APR_LIB

# Altium CAM / generated intermediates are not tracked. The reviewed, versioned
# manufacturing release (gerbers/BOM/CPL) lives under hardware/manufacturing/ and
# board exports under hardware/exports/ — both ARE tracked.
CAMtastic*.Cam
